rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tecnocreditoficial@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidFighter(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('record' in data) || (data.record is string && data.record.size() <= 50)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 500));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'status', 'fighters']) &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['upcoming', 'live', 'finished', 'cancelled'] &&
             data.fighters is list && data.fighters.size() >= 2 && data.fighters.size() <= 10;
    }

    function isValidBet(data) {
      return data.keys().hasAll(['userId', 'eventId', 'selection', 'amount', 'odds', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time &&
             isValidId(data.eventId) &&
             exists(/databases/$(database)/documents/events/$(data.eventId));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'method', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['deposit', 'withdrawal'] &&
             data.amount is number && data.amount > 0 &&
             data.method in ['paypal', 'bank', 'crypto'] &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    // Public read for fighters
    match /fighters/{fighterId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(fighterId) && isValidFighter(incoming());
      allow delete: if isAdmin();
    }

    // Public read for events
    match /events/{eventId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) && (
        // Prevent changing result unless finished
        (!('result' in incoming()) || existing().status == 'finished')
      );
      allow delete: if isAdmin();
    }

    // User specific bets
    match /bets/{betId} {
      allow read: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(betId) && isValidBet(incoming()) && 
                    get(/databases/$(database)/documents/events/$(incoming().eventId)).data.status == 'upcoming';
      allow update: if isAdmin(); // Only system can settle bets
      allow delete: if false; // Bets are permanent records
    }

    // User specific transactions
    match /transactions/{transactionId} {
      allow read: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isAdmin(); // Verification by admin
      allow delete: if false;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                    incoming().keys().hasAll(['balance', 'isAdmin', 'displayName']) && 
                    incoming().balance == 0 && 
                    (
                      (incoming().isAdmin == true && request.auth.token.email == 'tecnocreditoficial@gmail.com') ||
                      (incoming().isAdmin == false)
                    );
      allow update: if isAdmin() || (
        isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );
    }

    // Admins list
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }

    // Global settings (Payment accounts etc)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
